w::Result<()> {\n    let pdf_info = info(&args.file)?;\n\n    if args.json {\n        println!(\"{}\", serde_json::to_string_pretty(&pdf_info)?);\n        return Ok(());\n    }\n\n    println!(\"File:  {}\", args.file.display());\n    println!(\"Pages: {}\", pdf_info.page_count);\n    println!();\n    println!(\"{:<6} {:>10} {:>10}\", \"Page\", \"Width pt\", \"Height pt\");\n    println!(\"{:-<6} {:->10} {:->10}\", \"\", \"\", \"\");\n    for (i, (w, h)) in pdf_info.dimensions.iter().enumerate() {\n        let label = paper_size_label(*w, *h);\n        println!(\"{:<6} {:>10.1} {:>10.1}  {}\", i + 1, w, h, label);\n    }\n\n    let fields = [\n        (\"Title\", &pdf_info.title),\n        (\"Author\", &pdf_info.author),\n        (\"Subject\", &pdf_info.subject),\n        (\"Keywords\", &pdf_info.keywords),\n        (\"Creator\", &pdf_info.creator),\n        (\"Producer\", &pdf_info.producer),\n    ];\n    let has_meta = fields.iter().any(|(_, v)| v.is_some());\n    if has_meta {\n        println!();\n        for (label, value) in &fields {\n            if let Some(v) = value {\n                println!(\"{label:<10} {v}\");\n            }\n        }\n    }\n\n    Ok(())\n}\n\nfn paper_size_label(w: f64, h: f64) -> &'static str {\n    let matches = |a: f64, b: f64| (w - a).abs() < 2.0 && (h - b).abs() < 2.0;\n    if matches(612.0, 792.0) {\n        \"(Letter)\"\n    } else if matches(595.0, 842.0) {\n        \"(A4)\"\n    } else if matches(612.0, 1008.0) {\n        \"(Legal)\"\n    } else {\n        \"\"\n    }\n}\n","structuredPatch":[{"oldStart":28,"oldLines":11,"newStart":28,"newLines":24,"lines":["     println!(\"File:  {}\", args.file.display());","     println!(\"Pages: {}\", pdf_info.page_count);","     println!();","+    // Filter to requested pages if --pages flag provided","+    let page_indices: Vec<usize> = if let Some(ref page_spec) = args.pages {","+        ezpdf_core::page_range::parse(page_spec, pdf_info.page_count)","+            .map_err(anyhow::Error::from)?","+            .into_iter()","+            .map(|p| (p - 1) as usize)","+            .collect()","+    } else {","+        (0..pdf_info.dimensions.len()).collect()","+    };","+","     println!(\"{:<6} {:>10} {:>10}\", \"Page\", \"Width pt\", \"Height pt\");","     println!(\"{:-<6} {:->10} {:->10}\", \"\", \"\", \"\");","-    for (i, (w, h)) in pdf_info.dimensions.iter().enumerate() {","-        let label = paper_size_label(*w, *h);","-        println!(\"{:<6} {:>10.1} {:>10.1}  {}\", i + 1, w, h, label);","+    for i in &page_indices {","+        if let Some((w, h)) = pdf_info.dimensions.get(*i) {","+            let label = paper_size_label(*w, *h);","+            println!(\"{:<6} {:>10.1} {:>10.1}  {}\", i + 1, w, h, label);","+        }","     }"," ","     let fields = ["]}],"userModified":false,"replaceAll":false}}
