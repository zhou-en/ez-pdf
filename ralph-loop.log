{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01KdAgtFFrigNhBZHtJHSixP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KpJyrnNLpRqNoXBBPQ541H","name":"Write","input":{"file_path":"/Users/enzhou/Projects/ez-pdf/ezpdf-cli/tests/rotate_cli_tests.rs","content":"use assert_cmd::Command;\nuse lopdf::Document;\nuse std::path::Path;\nuse tempfile::NamedTempFile;\n\nfn fixture(name: &str) -> std::path::PathBuf {\n    Path::new(env!(\"CARGO_MANIFEST_DIR\"))\n        .parent()\n        .unwrap()\n        .join(\"ezpdf-core/tests/fixtures\")\n        .join(name)\n}\n\nfn get_page_rotation(path: &Path, page_num: u32) -> i64 {\n    let doc = Document::load(path).expect(\"load PDF\");\n    let pages = doc.get_pages();\n    let page_id = *pages.get(&page_num).expect(\"page\");\n    let page = doc.get_object(page_id).expect(\"object\");\n    let dict = page.as_dict().expect(\"dict\");\n    dict.get(b\"Rotate\")\n        .and_then(|r| r.as_i64())\n        .unwrap_or(0)\n}\n\n#[test]\nfn rotate_all_pages_exits_zero_and_prints_rotated() {\n    let out = NamedTempFile::new().unwrap();\n    let input = fixture(\"3page.pdf\");\n\n    Command::cargo_bin(\"ezpdf\")\n        .unwrap()\n        .args([\n            \"rotate\",\n            input.to_str().unwrap(),\n            \"90\",\n            \"-o\",\n            out.path().to_str().unwrap(),\n        ])\n        .assert()\n        .success()\n        .stdout(predicates::str::contains(\"Rotated\"));\n\n    assert_eq!(get_page_rotation(out.path(), 1), 90);\n}\n\n#[test]\nfn rotate_specific_pages_via_flag() {\n    let out = NamedTempFile::new().unwrap();\n    let input = fixture(\"3page.pdf\");\n\n    Command::cargo_bin(\"ezpdf\")\n        .unwrap()\n        .args([\n            \"rotate\",\n            input.to_str().unwrap(),\n            \"90\",\n            \"--pages\",\n            \"1,3\",\n            \"-o\",\n            out.path().to_str().unwrap(),\n        ])\n        .assert()\n        .success();\n\n    assert_eq!(get_page_rotation(out.path(), 1), 90);\n    assert_eq!(get_page_rotation(out.path(), 2), 0);\n    assert_eq!(get_page_rotation(out.path(), 3), 90);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":316,"cache_read_input_tokens":150181,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":316},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8b32962c-f496-4079-9ef0-4b12af617e35","uuid":"128cfd31-a2d1-4222-938e-7d26362a00ed"}
