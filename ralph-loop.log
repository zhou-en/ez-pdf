{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RJaxQfWUfkmMQrv44kSbVB","type":"tool_result","content":"     1→use std::fs::File;\n     2→use std::io::{BufWriter, Result, Write};\n     3→use std::path::Path;\n     4→use std::vec;\n     5→\n     6→use super::Object::*;\n     7→use super::{Dictionary, Document, Object, Stream, StringFormat};\n     8→use crate::{xref::*, IncrementalDocument};\n     9→\n    10→impl Document {\n    11→    /// Save PDF document to specified file path.\n    12→    #[inline]\n    13→    pub fn save<P: AsRef<Path>>(&mut self, path: P) -> Result<File> {\n    14→        let mut file = BufWriter::new(File::create(path)?);\n    15→        self.save_internal(&mut file)?;\n    16→        Ok(file.into_inner()?)\n    17→    }\n    18→\n    19→    /// Save PDF to arbitrary target\n    20→    #[inline]\n    21→    pub fn save_to<W: Write>(&mut self, target: &mut W) -> Result<()> {\n    22→        self.save_internal(target)\n    23→    }\n    24→\n    25→    fn save_internal<W: Write>(&mut self, target: &mut W) -> Result<()> {\n    26→        let mut target = CountingWrite {\n    27→            inner: target,\n    28→            bytes_written: 0,\n    29→        };\n    30→\n    31→        let mut xref = Xref::new(self.max_id + 1, self.reference_table.cross_reference_type);\n    32→        writeln!(target, \"%PDF-{}\", self.version)?;\n    33→\n    34→        for (&(id, generation), object) in &self.objects {\n    35→            if object\n    36→                .type_name()\n    37→                .map(|name| [\"ObjStm\", \"XRef\", \"Linearized\"].contains(&name))\n    38→                .ok()\n    39→                != Some(true)\n    40→            {\n    41→                Writer::write_indirect_object(&mut target, id, generation, object, &mut xref)?;\n    42→            }\n    43→        }\n    44→\n    45→        let xref_start = target.bytes_written;\n    46→\n    47→        // Pick right cross reference stream.\n    48→        match xref.cross_reference_type {\n    49→            XrefType::CrossReferenceTable => {\n    50→                Writer::write_xref(&mut target, &xref)?;\n    51→                self.write_trailer(&mut target)?;\n    52→            }\n    53→            XrefType::CrossReferenceStream => {\n    54→                // Cross Reference Stream instead of XRef and Trailer\n    55→                self.write_cross_reference_stream(&mut target, &mut xref, xref_start as u32)?;\n    56→            }\n    57→        }\n    58→        // Write `startxref` part of trailer\n    59→        write!(target, \"\\nstartxref\\n{}\\n%%EOF\", xref_start)?;\n    60→\n    61→        Ok(())\n    62→    }\n    63→\n    64→    /// Write the Cross Reference Stream.\n    65→    ///\n    66→    /// Insert an `Object` to the end of the PDF (not visible when inspecting `Document`).\n    67→    /// Note: This is different from the \"Cross Reference Table\".\n    68→    fn write_cross_reference_stream<W: Write>(\n    69→        &mut self, file: &mut CountingWrite<&mut W>, xref: &mut Xref, xref_start: u32,\n    70→    ) -> Result<()> {\n    71→        // Increment max_id to account for CRS.\n    72→        self.max_id += 1;\n    73→        let new_obj_id_for_crs = self.max_id;\n    74→        xref.insert(\n    75→            new_obj_id_for_crs,\n    76→            XrefEntry::Normal {\n    77→                offset: xref_start,\n    78→                generation: 0,\n    79→            },\n    80→        );\n    81→        self.trailer.set(\"Type\", Name(b\"XRef\".to_vec()));\n    82→        // Update `max_id` in trailer\n    83→        self.trailer.set(\"Size\", i64::from(self.max_id + 1));\n    84→        // Set the size of each entry in bytes (default for PDFs is `[1 2 1]`)\n    85→        // In our case we use `[u8, u32, u16]` for each entry\n    86→        // to keep things simple and working at all times.\n    87→        self.trailer.set(\"W\", Array(vec![Integer(1), Integer(4), Integer(2)]));\n    88→        // Note that `ASCIIHexDecode` does not work correctly,\n    89→        // but is still useful for debugging sometimes.\n    90→        let filter = XRefStreamFilter::None;\n    91→        let (stream, stream_length, indexes) = Writer::create_xref_steam(xref, filter)?;\n    92→        self.trailer.set(\"Index\", indexes);\n    93→\n    94→        if filter == XRefStreamFilter::ASCIIHexDecode {\n    95→            self.trailer.set(\"Filter\", Name(b\"ASCIIHexDecode\".to_vec()));\n    96→        } else {\n    97→            self.trailer.remove(b\"Filter\");\n    98→        }\n    99→\n   100→        self.trailer.set(\"Length\", stream_length as i64);\n   101→\n   102→        let trailer = &self.trailer;\n   103→        let cross_reference_stream = Stream(Stream {\n   104→            dict: trailer.clone(),\n   105→            allows_compression: true,\n   106→            content: stream,\n   107→            start_position: None,\n   108→        });\n   109→        // Insert Cross Reference Stream as an `Object` to the end of the PDF.\n   110→        // The `Object` is not added to `Document` because it is generated every time you save.\n   111→        Writer::write_indirect_object(file, new_obj_id_for_crs, 0, &cross_reference_stream, xref)?;\n   112→\n   113→        Ok(())\n   114→    }\n   115→\n   116→    fn write_trailer(&mut self, file: &mut dyn Write) -> Result<()> {\n   117→        self.trailer.set(\"Size\", i64::from(self.max_id + 1));\n   118→        file.write_all(b\"trailer\\n\")?;\n   119→        Writer::write_dictionary(file, &self.trailer)?;\n   120→        Ok(())\n   121→    }\n   122→}\n   123→\n   124→impl IncrementalDocument {\n   125→    /// Save PDF document to specified file path.\n   126→    #[inline]\n   127→    pub fn save<P: AsRef<Path>>(&mut self, path: P) -> Result<File> {\n   128→        let mut file = BufWriter::new(File::create(path)?);\n   129→        self.save_internal(&mut file)?;\n   130→        Ok(file.into_inner()?)\n   131→    }\n   132→\n   133→    /// Save PDF to arbitrary target\n   134→    #[inline]\n   135→    pub fn save_to<W: Write>(&mut self, target: &mut W) -> Result<()> {\n   136→        self.save_internal(target)\n   137→    }\n   138→\n   139→    fn save_internal<W: Write>(&mut self, target: &mut W) -> Result<()> {\n   140→        let mut target = CountingWrite {\n   141→            inner: target,\n   142→            bytes_written: 0,\n   143→        };\n   144→\n   145→        // Write previous document versions.\n   146→        let prev_document_bytes = self.get_prev_documents_bytes();\n   147→        target.inner.write_all(prev_document_bytes)?;\n   148→        target.bytes_written += prev_document_bytes.len();\n   149→\n   150→        // Write/Append new document version.\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01FXokgyM5w9vEMho7BzueFP","session_id":"8b32962c-f496-4079-9ef0-4b12af617e35","uuid":"08d35742-13bd-4161-b4c9-4b384138bdc0"}
