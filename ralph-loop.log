ult,\n            Err(EzPdfError::PageOutOfRange { .. }) | Err(EzPdfError::InvalidSyntax { .. })\n        ),\n        \"expected out-of-range error, got: {:?}\",\n        result\n    );\n}\n","structuredPatch":[],"originalFile":null}}
