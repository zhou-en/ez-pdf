{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017YKhFJtQpNVgHpdb2wzjsb","type":"tool_result","content":"     1→use super::encodings::{self, bytes_to_string, string_to_bytes};\n     2→use super::{Bookmark, Dictionary, Object, ObjectId};\n     3→use crate::encryption;\n     4→use crate::xref::{Xref, XrefType};\n     5→use crate::{Error, Result, Stream};\n     6→use encoding_rs::UTF_16BE;\n     7→use log::info;\n     8→use std::cmp::max;\n     9→use std::collections::{BTreeMap, HashMap};\n    10→use std::io::Write;\n    11→use std::str;\n    12→\n    13→/// A PDF document.\n    14→///\n    15→/// This can both be a combination of multiple incremental updates\n    16→/// or just one (the last) incremental update in a PDF file.\n    17→#[derive(Debug, Clone)]\n    18→pub struct Document {\n    19→    /// The version of the PDF specification to which the file conforms.\n    20→    pub version: String,\n    21→\n    22→    /// The trailer gives the location of the cross-reference table and of certain special objects.\n    23→    pub trailer: Dictionary,\n    24→\n    25→    /// The cross-reference table contains locations of the indirect objects.\n    26→    pub reference_table: Xref,\n    27→\n    28→    /// The objects that make up the document contained in the file.\n    29→    pub objects: BTreeMap<ObjectId, Object>,\n    30→\n    31→    /// Current maximum object id within the document.\n    32→    pub max_id: u32,\n    33→\n    34→    /// Current maximum object id within Bookmarks.\n    35→    pub max_bookmark_id: u32,\n    36→\n    37→    /// The bookmarks in the document. Render at the very end of document after renumbering objects.\n    38→    pub bookmarks: Vec<u32>,\n    39→\n    40→    /// used to locate a stored Bookmark so children can be appended to it via its id. Otherwise we\n    41→    /// need to do recursive lookups and returns on the bookmarks internal layout Vec\n    42→    pub bookmark_table: HashMap<u32, Bookmark>,\n    43→\n    44→    /// The byte the cross-reference table starts at.\n    45→    /// This value is only set during reading, but not when writing the file.\n    46→    /// It is used to support incremental updates in PDFs.\n    47→    /// Default value is `0`.\n    48→    pub xref_start: usize,\n    49→}\n    50→\n    51→impl Document {\n    52→    /// Create new PDF document.\n    53→    pub fn new() -> Self {\n    54→        Self {\n    55→            version: \"1.4\".to_string(),\n    56→            trailer: Dictionary::new(),\n    57→            reference_table: Xref::new(0, XrefType::CrossReferenceStream),\n    58→            objects: BTreeMap::new(),\n    59→            max_id: 0,\n    60→            max_bookmark_id: 0,\n    61→            bookmarks: Vec::new(),\n    62→            bookmark_table: HashMap::new(),\n    63→            xref_start: 0,\n    64→        }\n    65→    }\n    66→\n    67→    /// Create a new PDF document that is an incremental update to a previous document.\n    68→    pub fn new_from_prev(prev: &Document) -> Self {\n    69→        let mut new_trailer = prev.trailer.clone();\n    70→        new_trailer.set(\"Prev\", Object::Integer(prev.xref_start as i64));\n    71→        Self {\n    72→            version: \"1.4\".to_string(),\n    73→            trailer: new_trailer,\n    74→            reference_table: Xref::new(0, prev.reference_table.cross_reference_type),\n    75→            objects: BTreeMap::new(),\n    76→            max_id: prev.max_id,\n    77→            max_bookmark_id: prev.max_bookmark_id,\n    78→            bookmarks: Vec::new(),\n    79→            bookmark_table: HashMap::new(),\n    80→            xref_start: 0,\n    81→        }\n    82→    }\n    83→\n    84→    const DEREF_LIMIT: usize = 128;\n    85→\n    86→    fn recursive_fix_pages(&mut self, bookmarks: &[u32], first: bool) -> ObjectId {\n    87→        if !bookmarks.is_empty() {\n    88→            for id in bookmarks {\n    89→                let (children, mut page) = match self.bookmark_table.get(id) {\n    90→                    Some(n) => (n.children.clone(), n.page),\n    91→                    None => return (0, 0),\n    92→                };\n    93→\n    94→                if 0 == page.0 && !children.is_empty() {\n    95→                    let objectid = self.recursive_fix_pages(&children[..], false);\n    96→\n    97→                    let bookmark = self.bookmark_table.get_mut(id).unwrap();\n    98→                    bookmark.page = objectid;\n    99→                    page = objectid;\n   100→                }\n   101→\n   102→                if !first && 0 != page.0 {\n   103→                    return page;\n   104→                }\n   105→\n   106→                if first && !children.is_empty() {\n   107→                    self.recursive_fix_pages(&children[..], first);\n   108→                }\n   109→            }\n   110→        }\n   111→\n   112→        (0, 0)\n   113→    }\n   114→\n   115→    /// Adjusts the Parents that have a ObjectId of (0,_) to that\n   116→    /// of their first child. will recurse through all entries\n   117→    /// till all parents of children are set. This should be\n   118→    /// ran before building the final bookmark objects but after\n   119→    /// renumbering of objects.\n   120→    pub fn adjust_zero_pages(&mut self) {\n   121→        self.recursive_fix_pages(&self.bookmarks.clone(), true);\n   122→    }\n   123→\n   124→    /// Follow references if the supplied object is a reference.\n   125→    ///\n   126→    /// Returns a tuple of an optional object id and final object.\n   127→    /// The object id will be None if the object was not a\n   128→    /// reference. Otherwise, it will be the last object id in the\n   129→    /// reference chain.\n   130→    pub fn dereference<'a>(&'a self, mut object: &'a Object) -> Result<(Option<ObjectId>, &'a Object)> {\n   131→        let mut nb_deref = 0;\n   132→        let mut id = None;\n   133→\n   134→        while let Ok(ref_id) = object.as_reference() {\n   135→            id = Some(ref_id);\n   136→            object = self.objects.get(&ref_id).ok_or(Error::ObjectNotFound)?;\n   137→\n   138→            nb_deref += 1;\n   139→            if nb_deref > Self::DEREF_LIMIT {\n   140→                return Err(Error::ReferenceLimit);\n   141→            }\n   142→        }\n   143→\n   144→        Ok((id, object))\n   145→    }\n   146→\n   147→    /// Get object by object id, will iteratively dereference a referenced object.\n   148→    pub fn get_object(&self, id: ObjectId) -> Result<&Object> {\n   149→        let object = self.objects.get(&id).ok_or(Error::ObjectNotFound)?;\n   150→        self.dereference(object).map(|(_, object)| object)\n   151→    }\n   152→\n   153→    /// Determines if an object exists in the current document (or incremental update.)\n   154→    /// with the given `ObjectId`.\n   155→    /// `true` if the object exists, `false` if it does not exist.\n   156→    pub fn has_object(&self, id: ObjectId) -> bool {\n   157→        self.objects.get(&id).is_some()\n   158→    }\n   159→\n   160→    /// Get mutable reference to object by object id, will iteratively dereference a referenced object.\n   161→    pub fn get_object_mut(&mut self, id: ObjectId) -> Result<&mut Object> {\n   162→        let object = self.objects.get(&id).ok_or(Error::ObjectNotFound)?;\n   163→        let (ref_id, _) = self.dereference(object)?;\n   164→\n   165→        Ok(self.objects.get_mut(&ref_id.unwrap_or(id)).unwrap())\n   166→    }\n   167→\n   168→    /// Get page object_id of the specified object object_id\n   169→    pub fn get_object_page(&self, id: ObjectId) -> Result<ObjectId> {\n   170→        for (_, object_id) in self.get_pages() {\n   171→            let page = self.get_object(object_id)?.as_dict()?;\n   172→            let annots = page.get(b\"Annots\")?.as_array()?;\n   173→            let mut objects_ids = annots.iter().map(Object::as_reference);\n   174→\n   175→            let contains = objects_ids.any(|object_id| {\n   176→                if let Ok(object_id) = object_id {\n   177→                    return id == object_id;\n   178→                }\n   179→                false\n   180→            });\n   181→            if contains {\n   182→                return Ok(object_id);\n   183→            }\n   184→        }\n   185→\n   186→        Err(Error::ObjectNotFound)\n   187→    }\n   188→\n   189→    /// Get dictionary object by id.\n   190→    pub fn get_dictionary(&self, id: ObjectId) -> Result<&Dictionary> {\n   191→        self.get_object(id).and_then(Object::as_dict)\n   192→    }\n   193→\n   194→    /// Get a mutable dictionary object by id.\n   195→    pub fn get_dictionary_mut(&mut self, id: ObjectId) -> Result<&mut Dictionary> {\n   196→        self.get_object_mut(id).and_then(Object::as_dict_mut)\n   197→    }\n   198→\n   199→    /// Get dictionary in dictionary by key.\n   200→    pub fn get_dict_in_dict(&self, node: &Dictionary, key: &[u8]) -> Result<&Dictionary> {\n   201→        node.get(key)\n   202→            .and_then(Object::as_reference)\n   203→            .and_then(move |id| self.get_dictionary(id))\n   204→    }\n   205→\n   206→    /// Traverse objects from trailer recursively, return all referenced object IDs.\n   207→    pub fn traverse_objects<A: Fn(&mut Object)>(&mut self, action: A) -> Vec<ObjectId> {\n   208→        fn traverse_array<A: Fn(&mut Object)>(array: &mut [Object], action: &A, refs: &mut Vec<ObjectId>) {\n   209→            for item in array.iter_mut() {\n   210→                traverse_object(item, action, refs);\n   211→            }\n   212→        }\n   213→        fn traverse_dictionary<A: Fn(&mut Object)>(dict: &mut Dictionary, action: &A, refs: &mut Vec<ObjectId>) {\n   214→            for (_, v) in dict.iter_mut() {\n   215→                traverse_object(v, action, refs);\n   216→            }\n   217→        }\n   218→        fn traverse_object<A: Fn(&mut Object)>(object: &mut Object, action: &A, refs: &mut Vec<ObjectId>) {\n   219→            action(object);\n   220→            match *object {\n   221→                Object::Array(ref mut array) => traverse_array(array, action, refs),\n   222→                Object::Dictionary(ref mut dict) => traverse_dictionary(dict, action, refs),\n   223→                Object::Stream(ref mut stream) => traverse_dictionary(&mut stream.dict, action, refs),\n   224→                Object::Reference(id) => {\n   225→                    if !refs.contains(&id) {\n   226→                        refs.push(id);\n   227→                    }\n   228→                }\n   229→                _ => {}\n   230→            }\n   231→        }\n   232→        let mut refs = vec![];\n   233→        traverse_dictionary(&mut self.trailer, &action, &mut refs);\n   234→        let mut index = 0;\n   235→        while index < refs.len() {\n   236→            if let Some(object) = self.objects.get_mut(&refs[index]) {\n   237→                traverse_object(object, &action, &mut refs);\n   238→            }\n   239→            index += 1;\n   240→        }\n   241→        refs\n   242→    }\n   243→\n   244→    /// Return dictionary with encryption information\n   245→    pub fn get_encrypted(&self) -> Result<&Dictionary> {\n   246→        self.trailer\n   247→            .get(b\"Encrypt\")\n   248→            .and_then(Object::as_reference)\n   249→            .and_then(|id| self.get_dictionary(id))\n   250→    }\n   251→\n   252→    /// Return true is PDF document is encrypted\n   253→    pub fn is_encrypted(&self) -> bool {\n   254→        self.get_encrypted().is_ok()\n   255→    }\n   256→\n   257→    /// Replaces all encrypted Strings and Streams with their decrypted contents\n   258→    pub fn decrypt<P: AsRef<[u8]>>(&mut self, password: P) -> Result<()> {\n   259→\n   260→        // Find the ID of the encryption dict; we'll want to skip it when decrypting\n   261→        let encryption_obj_id = self.trailer\n   262→            .get(b\"Encrypt\")\n   263→            .and_then(Object::as_reference)?;\n   264→\n   265→        // Since PDF 1.5, metadata may or may not be encrypted; defaults to true\n   266→        let metadata_is_encrypted = self.get_object(encryption_obj_id)?\n   267→            .as_dict()?\n   268→            .get(b\"EncryptMetadata\")\n   269→            .and_then(|o| o.as_bool())\n   270→            .unwrap_or(true);\n   271→\n   272→        let key = encryption::get_encryption_key(self, &password, true)?;\n   273→        for (&id, obj) in self.objects.iter_mut() {\n   274→\n   275→            // The encryption dictionary is not encrypted, leave it alone\n   276→            if id == encryption_obj_id {\n   277→                continue;\n   278→            }\n   279→\n   280→            // If a Metadata stream but metadata isn't encrypted, leave it alone\n   281→            if obj.type_name().unwrap_or(\"\") == \"Metadata\" && !metadata_is_encrypted {\n   282→                continue;\n   283→            }\n   284→\n   285→            let decrypted = match encryption::decrypt_object(&key, id, &*obj) {\n   286→                Ok(content) => content,\n   287→                Err(encryption::DecryptionError::NotDecryptable) => {\n   288→                    continue;\n   289→                }\n   290→                Err(_err) => {\n   291→                    return Err(_err.into());\n   292→                }\n   293→            };\n   294→\n   295→            // Only strings and streams are encrypted\n   296→            match obj {\n   297→                Object::Stream(stream) => stream.set_content(decrypted),\n   298→                Object::String(ref mut content, _) => *content = decrypted,\n   299→                _ => {}\n   300→            }\n   301→        }\n   302→\n   303→        self.trailer.remove(b\"Encrypt\");\n   304→        Ok(())\n   305→    }\n   306→\n   307→    /// Return the PDF document catalog, which is the root of the document's object graph.\n   308→    pub fn catalog(&self) -> Result<&Dictionary> {\n   309→        self.trailer\n   310→            .get(b\"Root\")\n   311→            .and_then(Object::as_reference)\n   312→            .and_then(|id| self.get_dictionary(id))\n   313→    }\n   314→\n   315→    /// Return a mutable reference to the PDF document catalog, which is the root of the document's\n   316→    /// object graph.\n   317→    pub fn catalog_mut(&mut self) -> Result<&mut Dictionary> {\n   318→        self.trailer\n   319→            .get(b\"Root\")\n   320→            .and_then(Object::as_reference)\n   321→            .and_then(move |id| self.get_dictionary_mut(id))\n   322→    }\n   323→\n   324→    /// Get page numbers and corresponding object ids.\n   325→    pub fn get_pages(&self) -> BTreeMap<u32, ObjectId> {\n   326→        self.page_iter().enumerate().map(|(i, p)| ((i + 1) as u32, p)).collect()\n   327→    }\n   328→\n   329→    pub fn page_iter(&self) -> impl Iterator<Item = ObjectId> + '_ {\n   330→        PageTreeIter::new(self)\n   331→    }\n   332→\n   333→    /// Get content stream object ids of a page.\n   334→    pub fn get_page_contents(&self, page_id: ObjectId) -> Vec<ObjectId> {\n   335→        let mut streams = vec![];\n   336→        if let Ok(page) = self.get_dictionary(page_id) {\n   337→            if let Ok(contents) = page.get(b\"Contents\") {\n   338→                match *contents {\n   339→                    Object::Reference(ref id) => {\n   340→                        streams.push(*id);\n   341→                    }\n   342→                    Object::Array(ref arr) => {\n   343→                        for content in arr {\n   344→                            if let Ok(id) = content.as_reference() {\n   345→                                streams.push(id)\n   346→                            }\n   347→                        }\n   348→                    }\n   349→                    _ => {}\n   350→                }\n   351→            }\n   352→        }\n   353→        streams\n   354→    }\n   355→\n   356→    /// Add content to a page. All existing content will be unchanged.\n   357→    pub fn add_page_contents(&mut self, page_id: ObjectId, content: Vec<u8>) -> Result<()> {\n   358→        if let Ok(page) = self.get_dictionary(page_id) {\n   359→            // Prepare new value\n   360→            let mut current_content_list: Vec<Object> = match page.get(b\"Contents\") {\n   361→                Ok(Object::Reference(ref id)) => {\n   362→                    // Covert reference to array\n   363→                    vec![Object::Reference(*id)]\n   364→                }\n   365→                Ok(Object::Array(ref arr)) => arr.clone(),\n   366→                Err(Error::DictKey) => vec![],\n   367→                _ => vec![],\n   368→            };\n   369→            let content_object_id = self.add_object(Object::Stream(Stream::new(Dictionary::new(), content)));\n   370→            current_content_list.push(Object::Reference(content_object_id));\n   371→            // Set data\n   372→\n   373→            let page_mut = self.get_object_mut(page_id).and_then(Object::as_dict_mut).unwrap();\n   374→            page_mut.set(\"Contents\", current_content_list);\n   375→            Ok(())\n   376→        } else {\n   377→            Err(Error::ObjectNotFound)\n   378→        }\n   379→    }\n   380→\n   381→    /// Get content of a page.\n   382→    pub fn get_page_content(&self, page_id: ObjectId) -> Result<Vec<u8>> {\n   383→        let mut content = Vec::new();\n   384→        let content_streams = self.get_page_contents(page_id);\n   385→        for object_id in content_streams {\n   386→            if let Ok(content_stream) = self.get_object(object_id).and_then(Object::as_stream) {\n   387→                match content_stream.decompressed_content() {\n   388→                    Ok(data) => content.write_all(&data)?,\n   389→                    Err(_) => content.write_all(&content_stream.content)?,\n   390→                };\n   391→            }\n   392→        }\n   393→        Ok(content)\n   394→    }\n   395→\n   396→    /// Get resources used by a page.\n   397→    pub fn get_page_resources(&self, page_id: ObjectId) -> (Option<&Dictionary>, Vec<ObjectId>) {\n   398→        fn collect_resources(page_node: &Dictionary, resource_ids: &mut Vec<ObjectId>, doc: &Document) {\n   399→            if let Ok(resources_id) = page_node.get(b\"Resources\").and_then(Object::as_reference) {\n   400→                resource_ids.push(resources_id);\n   401→            }\n   402→            if let Ok(page_tree) = page_node\n   403→                .get(b\"Parent\")\n   404→                .and_then(Object::as_reference)\n   405→                .and_then(|id| doc.get_dictionary(id))\n   406→            {\n   407→                collect_resources(page_tree, resource_ids, doc);\n   408→            }\n   409→        }\n   410→\n   411→        let mut resource_dict = None;\n   412→        let mut resource_ids = Vec::new();\n   413→        if let Ok(page) = self.get_dictionary(page_id) {\n   414→            resource_dict = page.get(b\"Resources\").and_then(Object::as_dict).ok();\n   415→            collect_resources(page, &mut resource_ids, self);\n   416→        }\n   417→        (resource_dict, resource_ids)\n   418→    }\n   419→\n   420→    /// Get fonts used by a page.\n   421→    pub fn get_page_fonts(&self, page_id: ObjectId) -> BTreeMap<Vec<u8>, &Dictionary> {\n   422→        fn collect_fonts_from_resources<'a>(\n   423→            resources: &'a Dictionary, fonts: &mut BTreeMap<Vec<u8>, &'a Dictionary>, doc: &'a Document,\n   424→        ) {\n   425→            if let Ok(font_dict) = resources.get(b\"Font\").and_then(Object::as_dict) {\n   426→                for (name, value) in font_dict.iter() {\n   427→                    let font = match *value {\n   428→                        Object::Reference(id) => doc.get_dictionary(id).ok(),\n   429→                        Object::Dictionary(ref dict) => Some(dict),\n   430→                        _ => None,\n   431→                    };\n   432→                    if !fonts.contains_key(name) {\n   433→                        font.map(|font| fonts.insert(name.clone(), font));\n   434→                    }\n   435→                }\n   436→            }\n   437→        }\n   438→\n   439→        let mut fonts = BTreeMap::new();\n   440→        let (resource_dict, resource_ids) = self.get_page_resources(page_id);\n   441→        if let Some(resources) = resource_dict {\n   442→            collect_fonts_from_resources(resources, &mut fonts, self);\n   443→        }\n   444→        for resource_id in resource_ids {\n   445→            if let Ok(resources) = self.get_dictionary(resource_id) {\n   446→                collect_fonts_from_resources(resources, &mut fonts, self);\n   447→            }\n   448→        }\n   449→        fonts\n   450→    }\n   451→\n   452→    /// Get the PDF annotations of a page. The /Subtype of each annotation dictionary defines the\n   453→    /// annotation type (Text, Link, Highlight, Underline, Ink, Popup, Widget, etc.). The /Rect of\n   454→    /// an annotation dictionary defines its location on the page.\n   455→    pub fn get_page_annotations(&self, page_id: ObjectId) -> Vec<&Dictionary> {\n   456→        let mut annotations = vec![];\n   457→        if let Ok(page) = self.get_dictionary(page_id) {\n   458→            match page.get(b\"Annots\") {\n   459→                Ok(Object::Reference(ref id)) => self\n   460→                    .get_object(*id)\n   461→                    .and_then(Object::as_array)\n   462→                    .unwrap()\n   463→                    .iter()\n   464→                    .flat_map(Object::as_reference)\n   465→                    .flat_map(|id| self.get_dictionary(id))\n   466→                    .for_each(|a| annotations.push(a)),\n   467→                Ok(Object::Array(ref a)) => a\n   468→                    .iter()\n   469→                    .flat_map(Object::as_reference)\n   470→                    .flat_map(|id| self.get_dictionary(id))\n   471→                    .for_each(|a| annotations.push(a)),\n   472→                _ => {}\n   473→            }\n   474→        }\n   475→        annotations\n   476→    }\n   477→\n   478→    pub fn decode_text(encoding: Option<&str>, bytes: &[u8]) -> String {\n   479→        if let Some(encoding) = encoding {\n   480→            info!(\"{}\", encoding);\n   481→            match encoding {\n   482→                \"StandardEncoding\" => bytes_to_string(encodings::STANDARD_ENCODING, bytes),\n   483→                \"MacRomanEncoding\" => bytes_to_string(encodings::MAC_ROMAN_ENCODING, bytes),\n   484→                \"MacExpertEncoding\" => bytes_to_string(encodings::MAC_EXPERT_ENCODING, bytes),\n   485→                \"WinAnsiEncoding\" => bytes_to_string(encodings::WIN_ANSI_ENCODING, bytes),\n   486→                \"UniGB-UCS2-H\" | \"UniGB−UTF16−H\" => UTF_16BE.decode(bytes).0.to_string(),\n   487→                \"Identity-H\" => \"?Identity-H Unimplemented?\".to_string(), // Unimplemented\n   488→                _ => String::from_utf8_lossy(bytes).to_string(),\n   489→            }\n   490→        } else {\n   491→            bytes_to_string(encodings::STANDARD_ENCODING, bytes)\n   492→        }\n   493→    }\n   494→\n   495→    pub fn encode_text(encoding: Option<&str>, text: &str) -> Vec<u8> {\n   496→        if let Some(encoding) = encoding {\n   497→            match encoding {\n   498→                \"StandardEncoding\" => string_to_bytes(encodings::STANDARD_ENCODING, text),\n   499→                \"MacRomanEncoding\" => string_to_bytes(encodings::MAC_ROMAN_ENCODING, text),\n   500→                \"MacExpertEncoding\" => string_to_bytes(encodings::MAC_EXPERT_ENCODING, text),\n   501→                \"WinAnsiEncoding\" => string_to_bytes(encodings::WIN_ANSI_ENCODING, text),\n   502→                \"UniGB-UCS2-H\" | \"UniGB−UTF16−H\" => UTF_16BE.encode(text).0.to_vec(),\n   503→                \"Identity-H\" => vec![], // Unimplemented\n   504→                _ => text.as_bytes().to_vec(),\n   505→            }\n   506→        } else {\n   507→            string_to_bytes(encodings::STANDARD_ENCODING, text)\n   508→        }\n   509→    }\n   510→}\n   511→\n   512→impl Default for Document {\n   513→    fn default() -> Self {\n   514→        Self::new()\n   515→    }\n   516→}\n   517→\n   518→struct PageTreeIter<'a> {\n   519→    doc: &'a Document,\n   520→    stack: Vec<&'a [Object]>,\n   521→    kids: Option<&'a [Object]>,\n   522→    iter_limit: usize,\n   523→}\n   524→\n   525→impl<'a> PageTreeIter<'a> {\n   526→    const PAGE_TREE_DEPTH_LIMIT: usize = 256;\n   527→\n   528→    fn new(doc: &'a Document) -> Self {\n   529→        if let Ok(page_tree_id) = doc\n   530→            .catalog()\n   531→            .and_then(|cat| cat.get(b\"Pages\"))\n   532→            .and_then(Object::as_reference)\n   533→        {\n   534→            Self {\n   535→                doc,\n   536→                kids: Self::kids(doc, page_tree_id),\n   537→                stack: Vec::with_capacity(32),\n   538→                iter_limit: doc.objects.len(),\n   539→            }\n   540→        } else {\n   541→            Self {\n   542→                doc,\n   543→                kids: None,\n   544→                stack: Vec::new(),\n   545→                iter_limit: doc.objects.len(),\n   546→            }\n   547→        }\n   548→    }\n   549→\n   550→    fn kids(doc: &Document, page_tree_id: ObjectId) -> Option<&[Object]> {\n   551→        doc.get_dictionary(page_tree_id)\n   552→            .and_then(|page_tree| page_tree.get(b\"Kids\"))\n   553→            .and_then(Object::as_array)\n   554→            .map(|k| k.as_slice())\n   555→            .ok()\n   556→    }\n   557→}\n   558→\n   559→impl Iterator for PageTreeIter<'_> {\n   560→    type Item = ObjectId;\n   561→\n   562→    fn next(&mu