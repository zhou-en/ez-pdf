{\n    if inputs.is_empty() {\n        return Err(EzPdfError::InvalidSyntax {\n            input: String::new(),\n            hint: \"merge requires at least one input file\".to_string(),\n        });\n    }\n\n    let mut docs: Vec<Document> = inputs\n        .iter()\n        .map(|p| load_doc(p))\n        .collect::<Result<_, _>>()?;\n\n    let mut target = docs.remove(0);\n    for doc in docs {\n        target.extend_with(doc);\n    }\n\n    target.save(output).map_err(EzPdfError::Io)\n}\n\nfn load_doc(path: &Path) -> Result<Document, EzPdfError> {\n    Document::load(path).map_err(|e| {\n        // lopdf returns its own error type; map to Io or EncryptedPdf\n        let msg = e.to_string();\n        if msg.contains(\"encrypted\") || msg.contains(\"password\") {\n            EzPdfError::EncryptedPdf\n        } else {\n            EzPdfError::Io(std::io::Error::new(std::io::ErrorKind::Other, msg))\n        }\n    })\n}\n"}}
