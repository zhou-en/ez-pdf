{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011zc33iDbasqWNY9ZLTU4Uh","type":"tool_result","content":"     1→use crate::{Dictionary, Document, Object, ObjectId};\n     2→use crate::{Error, Result};\n     3→\n     4→impl Document {\n     5→    /// Create new PDF document with version.\n     6→    pub fn with_version<S: Into<String>>(version: S) -> Document {\n     7→        let mut document = Self::new();\n     8→        document.version = version.into();\n     9→        document\n    10→    }\n    11→\n    12→    /// Create an object ID.\n    13→    pub fn new_object_id(&mut self) -> ObjectId {\n    14→        self.max_id += 1;\n    15→        (self.max_id, 0)\n    16→    }\n    17→\n    18→    /// Add PDF object into document's object list.\n    19→    pub fn add_object<T: Into<Object>>(&mut self, object: T) -> ObjectId {\n    20→        self.max_id += 1;\n    21→        let id = (self.max_id, 0);\n    22→        self.objects.insert(id, object.into());\n    23→        id\n    24→    }\n    25→\n    26→    pub fn set_object<T: Into<Object>>(&mut self, id: ObjectId, object: T) {\n    27→        self.objects.insert(id, object.into());\n    28→    }\n    29→\n    30→    /// Remove PDF object from document's object list.\n    31→    pub fn remove_object(&mut self, object_id: &ObjectId) -> Result<()> {\n    32→        for (_, page_id) in self.get_pages() {\n    33→            let page = self.get_object_mut(page_id)?.as_dict_mut()?;\n    34→            let annots = page.get_mut(b\"Annots\")?.as_array_mut()?;\n    35→\n    36→            annots.retain(|object| {\n    37→                if let Ok(id) = object.as_reference() {\n    38→                    return id != *object_id;\n    39→                }\n    40→\n    41→                true\n    42→            });\n    43→        }\n    44→\n    45→        Ok(())\n    46→    }\n    47→\n    48→    /// Get the pages resources. (Errors in case of reference)\n    49→    ///\n    50→    /// Get Object that has the key \"Resources\".\n    51→    fn get_or_create_resources_mut(&mut self, page_id: ObjectId) -> Result<&mut Object> {\n    52→        let page = self.get_object_mut(page_id).and_then(Object::as_dict_mut)?;\n    53→        if page.has(b\"Resources\") {\n    54→            if let Ok(_res_id) = page.get(b\"Resources\").and_then(Object::as_reference) {\n    55→                // Find and return referenced object.\n    56→                // Note: This returns an error because we can not have 2 mut barrow for `*self`.\n    57→                // self.get_object_mut(res_id)\n    58→                Err(Error::ObjectNotFound)\n    59→            } else {\n    60→                // It exists and is not a reference.\n    61→                page.get_mut(b\"Resources\")\n    62→            }\n    63→        } else {\n    64→            // \"Resources\" key does not exist, So create it.\n    65→            page.set(\"Resources\", Dictionary::new());\n    66→            page.get_mut(b\"Resources\")\n    67→        }\n    68→    }\n    69→\n    70→    /// Get the pages resources.\n    71→    ///\n    72→    /// Get Object that has the key \"Resources\".\n    73→    pub fn get_or_create_resources(&mut self, page_id: ObjectId) -> Result<&mut Object> {\n    74→        let resources_id = {\n    75→            let page = self.get_object(page_id).and_then(Object::as_dict)?;\n    76→            if page.has(b\"Resources\") {\n    77→                page.get(b\"Resources\").and_then(Object::as_reference).ok()\n    78→            } else {\n    79→                None\n    80→            }\n    81→        };\n    82→        match resources_id {\n    83→            Some(res_id) => self.get_object_mut(res_id),\n    84→            None => self.get_or_create_resources_mut(page_id),\n    85→        }\n    86→    }\n    87→\n    88→    /// Add XObject to a page.\n    89→    ///\n    90→    /// Get Object that has the key `Resources -> XObject`.\n    91→    pub fn add_xobject<N: Into<Vec<u8>>>(\n    92→        &mut self, page_id: ObjectId, xobject_name: N, xobject_id: ObjectId,\n    93→    ) -> Result<()> {\n    94→        if let Ok(resources) = self.get_or_create_resources(page_id).and_then(Object::as_dict_mut) {\n    95→            if !resources.has(b\"XObject\") {\n    96→                resources.set(\"XObject\", Dictionary::new());\n    97→            }\n    98→            let mut xobjects = resources.get_mut(b\"XObject\")?;\n    99→            if let Object::Reference(xobjects_ref_id) = xobjects {\n   100→                let mut xobjects_id = *xobjects_ref_id;\n   101→                while let Object::Reference(id) = self.get_object(xobjects_id)? {\n   102→                    xobjects_id = *id;\n   103→                }\n   104→                xobjects = self.get_object_mut(xobjects_id)?;\n   105→            }\n   106→            let xobjects = Object::as_dict_mut(xobjects)?;\n   107→            xobjects.set(xobject_name, Object::Reference(xobject_id));\n   108→        }\n   109→        Ok(())\n   110→    }\n   111→\n   112→    /// Add Graphics State to a page.\n   113→    ///\n   114→    /// Get Object that has the key `Resources -> ExtGState`.\n   115→    pub fn add_graphics_state<N: Into<Vec<u8>>>(\n   116→        &mut self, page_id: ObjectId, gs_name: N, gs_id: ObjectId,\n   117→    ) -> Result<()> {\n   118→        if let Ok(resources) = self.get_or_create_resources(page_id).and_then(Object::as_dict_mut) {\n   119→            if !resources.has(b\"ExtGState\") {\n   120→                resources.set(\"ExtGState\", Dictionary::new());\n   121→            }\n   122→            let states = resources.get_mut(b\"ExtGState\").and_then(Object::as_dict_mut)?;\n   123→            states.set(gs_name, Object::Reference(gs_id));\n   124→        }\n   125→        Ok(())\n   126→    }\n   127→}\n   128→\n   129→#[cfg(test)]\n   130→pub mod tests {\n   131→    use std::path::PathBuf;\n   132→\n   133→    use crate::content::*;\n   134→    use crate::{Document, Object, Stream};\n   135→\n   136→    /// Create and return a document for testing\n   137→    pub fn create_document() -> Document {\n   138→        let mut doc = Document::with_version(\"1.5\");\n   139→        let info_id = doc.add_object(dictionary! {\n   140→            \"Title\" => Object::string_literal(\"Create PDF document example\"),\n   141→            \"Creator\" => Object::string_literal(\"https://crates.io/crates/lopdf\"),\n   142→            \"CreationDate\" => time::OffsetDateTime::now_utc(),\n   143→        });\n   144→        let pages_id = doc.new_object_id();\n   145→        let font_id = doc.add_object(dictionary! {\n   146→            \"Type\" => \"Font\",\n   147→            \"Subtype\" => \"Type1\",\n   148→            \"BaseFont\" => \"Courier\",\n   149→        });\n   150→        let resources_id = doc.add_object(dictionary! {\n   151→            \"Font\" => dictionary! {\n   152→                \"F1\" => font_id,\n   153→            },\n   154→        });\n   155→        let content = Content {\n   156→            operations: vec![\n   157→                Operation::new(\"BT\", vec![]),\n   158→                Operation::new(\"Tf\", vec![\"F1\".into(), 48.into()]),\n   159→                Operation::new(\"Td\", vec![100.into(), 600.into()]),\n   160→                Operation::new(\"Tj\", vec![Object::string_literal(\"Hello World!\")]),\n   161→                Operation::new(\"ET\", vec![]),\n   162→            ],\n   163→        };\n   164→        let content_id = doc.add_object(Stream::new(dictionary! {}, content.encode().unwrap()));\n   165→        let page_id = doc.add_object(dictionary! {\n   166→            \"Type\" => \"Page\",\n   167→            \"Parent\" => pages_id,\n   168→            \"Contents\" => content_id,\n   169→        });\n   170→        let pages = dictionary! {\n   171→            \"Type\" => \"Pages\",\n   172→            \"Kids\" => vec![page_id.into()],\n   173→            \"Count\" => 1,\n   174→            \"Resources\" => resources_id,\n   175→            \"MediaBox\" => vec![0.into(), 0.into(), 595.into(), 842.into()],\n   176→        };\n   177→        doc.objects.insert(pages_id, Object::Dictionary(pages));\n   178→        let catalog_id = doc.add_object(dictionary! {\n   179→            \"Type\" => \"Catalog\",\n   180→            \"Pages\" => pages_id,\n   181→        });\n   182→        doc.trailer.set(\"Root\", catalog_id);\n   183→        doc.trailer.set(\"Info\", info_id);\n   184→        doc.compress();\n   185→\n   186→        doc\n   187→    }\n   188→\n   189→    /// Save a document\n   190→    pub fn save_document(file_path: &PathBuf, doc: &mut Document) {\n   191→        let res = doc.save(file_path);\n   192→\n   193→        assert!(match res {\n   194→            Ok(_file) => true,\n   195→            Err(_e) => false,\n   196→        });\n   197→    }\n   198→\n   199→    #[test]\n   200→    fn save_created_document() {\n   201→        // Create temporary folder to store file.\n   202→        let temp_dir = tempfile::tempdir().unwrap();\n   203→        let file_path = temp_dir.path().join(\"test_1_create.pdf\");\n   204→\n   205→        let mut doc = create_document();\n   206→        // Save to file\n   207→        save_document(&file_path, &mut doc);\n   208→        assert!(file_path.exists());\n   209→    }\n   210→}\n   211→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01FXokgyM5w9vEMho7BzueFP","session_id":"8b32962c-f496-4079-9ef0-4b12af617e35","uuid":"232a4899-9b4f-46d2-b319-70a5c18d27d7"}
