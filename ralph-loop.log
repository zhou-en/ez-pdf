map_or(false, |e| e == \"pdf\")\n        })\n        .count();\n    assert_eq!(pdf_count, 3);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":436,"cache_read_input_tokens":138074,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":436},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8b32962c-f496-4079-9ef0-4b12af617e35","uuid":"8cfa18ce-38ce-4d56-9e40-1f239f4bb654"}
