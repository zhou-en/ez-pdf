#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules/@tauri-apps/cli/node_modules:/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules/@tauri-apps/node_modules:/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules:/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules/@tauri-apps/cli/node_modules:/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules/@tauri-apps/node_modules:/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules:/Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../tauri.js" "$@"
else
  exec node  "$basedir/../../tauri.js" "$@"
fi
