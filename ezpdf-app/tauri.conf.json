{
  "productName": "ezpdf",
  "version": "0.1.0",
  "identifier": "com.ezpdf.app",
  "build": {
    "beforeDevCommand": "pnpm --dir /Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend dev",
    "beforeBuildCommand": "pnpm --dir /Users/enzhou/Projects/ez-pdf/ezpdf-app/frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "ezpdf",
        "width": 900,
        "height": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
